# Baseline Configuration
# Copy to .env and customize, then run: docker compose up

# === Required ===
DATABASE_URL=postgresql://baseline:baseline@localhost:5432/baseline
AUTH_SECRET=change-me-to-a-random-string

# === GitHub Integration ===
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_TOKEN=
GITHUB_USERNAME=

# === Optional ===
# RESEND_API_KEY=re_your_key
# CONTACT_EMAIL=you@example.com
