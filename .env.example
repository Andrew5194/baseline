# Baseline configuration — copy to .env and fill in.
#
#   Self-host:  docker compose pull && docker compose up -d   → http://localhost:3002
#   Develop:    make dev   (host apps + the compose postgres)
#
# Only AUTH_SECRET is required. Everything below it is optional — uncomment a line
# to turn that feature on. Postgres and ports have working defaults.


# ============================================================================
#  REQUIRED
# ============================================================================

# Signing key for login sessions. Compose refuses to start until this is set.
# `make setup` (and `make local`/`remote`) generate one here automatically;
# to set it by hand: openssl rand -base64 32
AUTH_SECRET=


# ============================================================================
#  OPTIONAL — integrations (Baseline runs fine without them)
# ============================================================================

# GitHub activity integration — connect it from the Sources page.
# NOT needed to sign in: Baseline uses email + password. Enable this only to pull
# your GitHub activity. Create an OAuth app at github.com/settings/developers with
# callback URL <your-url>/v1/integrations/github/callback
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Google Calendar integration. OAuth Web client (Calendar API enabled) with
# redirect URI http://localhost:3002/v1/integrations/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=


# ============================================================================
#  OPTIONAL — database & ports (defaults work out of the box)
# ============================================================================

# POSTGRES_USER=baseline
# POSTGRES_PASSWORD=baseline
# POSTGRES_DB=baseline
# WEB_PORT=3002


# ============================================================================
#  OPTIONAL — advanced networking (leave unset for the default same-origin setup)
# ============================================================================

# Pin the dashboard's public origin; unset = auto-detect (localhost or a reverse
# proxy such as the Coder proxy). If set, it must match the OAuth callback URLs.
# WEB_URL=
# Server-side address the web app uses to reach the API over the docker network.
# API_INTERNAL_URL=http://api:3001
# Call the API directly from the browser on a separate origin (split-origin deploys).
# NEXT_PUBLIC_API_URL=

# Local dev only (make dev): the compose API builds DATABASE_URL from the POSTGRES_*
# vars above; set this only when running the API on the host against the container.
# DATABASE_URL=postgresql://baseline:baseline@localhost:5432/baseline
